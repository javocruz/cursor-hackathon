# Copy to `.env` in the project root (or set variables in your host / Vercel dashboard).
# Loaded automatically by pydantic-settings when running the API.

# --- LLM providers (at least one key is required for pipeline execution) ---

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=

# --- OpenAI ---
OPENAI_API_KEY=

# Optional: defaults used when a node omits `model` in the graph payload
DEFAULT_ANTHROPIC_MODEL=claude-sonnet-4-20250514
DEFAULT_OPENAI_MODEL=gpt-4o-mini

# --- Auth ---
# Set to 1 to bypass JWT auth (auto-creates a dev user).
# Required until the frontend implements login/register UI.
AUTH_DISABLED=1

# Secret used to sign JWTs (change in production when auth is enabled).
# JWT_SECRET=change-me-in-production

# --- Database ---
# docker-compose sets this automatically; only needed for local/custom setups.
# DATABASE_URL=postgresql+psycopg://agentcanvas:agentcanvas@localhost:5432/agentcanvas
